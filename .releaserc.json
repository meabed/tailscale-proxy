{
  "branches": [
    "main",
    "master",
    "next",
    { "name": "beta", "prerelease": true },
    { "name": "alpha", "prerelease": true }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "angular",
        "releaseRules": [
          { "breaking": true, "release": "major" },
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "revert", "release": "patch" },
          { "type": "docs", "release": false },
          { "type": "style", "release": false },
          { "type": "test", "release": false },
          { "type": "build", "release": false },
          { "type": "ci", "release": false },
          { "type": "chore", "release": false }
        ],
        "parserOpts": { "noteKeywords": ["BREAKING CHANGE", "BREAKING CHANGES", "BREAKING"] }
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "angular",
        "parserOpts": { "noteKeywords": ["BREAKING CHANGE", "BREAKING CHANGES", "BREAKING"] }
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "GORELEASER_CURRENT_TAG=v${nextRelease.version} goreleaser release --clean --skip=publish,validate,announce && node npm/build-platform-packages.mjs ${nextRelease.version} && node scripts/stamp-version.mjs ${nextRelease.version}",
        "publishCmd": "node scripts/publish-platform-packages.mjs ${nextRelease.version} && node scripts/publish-homebrew.mjs ${nextRelease.version}"
      }
    ],
    ["@semantic-release/npm", { "npmPublish": true }],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "dist/*.tar.gz", "label": "binary archive" },
          { "path": "dist/*.zip", "label": "binary archive" },
          { "path": "dist/checksums.txt", "label": "checksums" }
        ],
        "successCommentCondition": "<% return !!issue.pull_request; %>",
        "failCommentCondition": "<% return !!issue.pull_request; %>"
      }
    ]
  ],
  "ci": true
}
